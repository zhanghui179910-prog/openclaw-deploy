# ===============================================
# OpenClaw 环境配置文件
# 请复制此文件为 .env 并填入您的真实配置
# ===============================================

# ---- DeepSeek API 配置 ----
# DeepSeek API 基础 URL（通常不需要修改）
DEEPSEEK_BASE_URL=https://api.deepseek.com

# DeepSeek API Key（从 https://platform.deepseek.com/ 获取）
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ---- 硅基流动 API 配置（备选）----
# 硅基流动 API 基础 URL
SILICON_FLOW_BASE_URL=https://api.siliconflow.cn

# 硅基流动 API Key（从 https://cloud.siliconflow.cn/ 获取）
SILICON_FLOW_API_KEY=your_silicon_flow_api_key_here

# ---- 智谱 AI (GLM) 配置（备选）----
# 智谱 AI 基础 URL
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# 智谱 AI API Key（从 https://open.bigmodel.cn/ 获取）
ZHIPU_API_KEY=your_zhipu_api_key_here

# ---- OpenClaw 应用配置 ----
# 当前使用的 AI 提供商（可选: deepseek / silicon_flow / zhipu）
CURRENT_PROVIDER=deepseek

# 日志级别（可选: DEBUG / INFO / WARNING / ERROR）
LOG_LEVEL=INFO

# 工作空间路径（容器内）
WORKSPACE_PATH=/workspace
